# Preferred: Google Gemini (OpenAI-compatible endpoint via openai package)
GEMINI_API_KEY=
# Optional overrides:
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash
# Alternatives: gemini-flash-latest, gemini-2.5-flash-lite
# (Alias) GOOGLE_API_KEY=  — same as GEMINI_API_KEY if you prefer that name

# Alternatives:
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
#
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
